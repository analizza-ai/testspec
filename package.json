{
  "name": "@analizza-ai/testspec",
  "version": "0.1.1",
  "description": "Spec Driven Test — the test layer for SDD",
  "type": "module",
  "bin": {
    "testspec": "./bin/cli.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src bin tests",
    "lint:fix": "eslint src bin tests --fix"
  },
  "keywords": [
    "sdd",
    "spec-driven",
    "test-generation",
    "testspec",
    "openspec",
    "claude",
    "ai-testing"
  ],
  "author": "Diego Lirio <diegolirio.dl@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/analizza-ai/testspec.git"
  },
  "bugs": {
    "url": "https://github.com/analizza-ai/testspec/issues"
  },
  "homepage": "https://github.com/analizza-ai/testspec#readme",
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "eslint": "^9.0.0",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.30.0"
  }
}
